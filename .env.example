PORT=4500
NODE_ENV=production
DOWNLOADS_DIR=/tmp/downloads
MAX_CONCURRENT_DOWNLOADS=1

# Required for Spotify playlists
# Get these at: https://developer.spotify.com/dashboard
# → Create App → Redirect URI: http://localhost:4500 → copy Client ID + Secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — YouTube Data API v3 (falls back to yt-dlp search if omitted)
# Enable at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# Optional — FlareSolverr for Cloudflare bypass on some sources
# FLARESOLVERR_URL=http://localhost:8191/v1
